# Kongo environment configuration
# Load with: set -a; source ./kongo.env; set +a

# ============================================================
# Server and authentication
# ============================================================
KONGODB_PORT=8080
# Prefix for every HTTP route. Default Admin UI: /_/kdb/admin/
KONGODB_BASE_PATH=/_/kdb
# Authentication mode: access_key|none. Use none only for trusted local development.
KONGODB_AUTH_MODE=access_key
# Required in access_key mode; also used as the browser Basic-auth password.
KONGODB_ACCESS_KEY=
# Comma-separated origins for standalone browser clients. Bundled Admin UI is same-origin.
KONGODB_CORS_ALLOWED_ORIGINS=
# Maximum request body size and operation execution time.
KONGODB_MAX_REQUEST_BYTES=16777216
KONGODB_OPERATION_TIMEOUT_MS=30000

# ============================================================
# Built-in admin web interfaces
# ============================================================
# Admin UI is served from ${KONGODB_BASE_PATH}/admin/.
KONGODB_ADMIN_UI_ENABLED=true
# Docs are served from ${KONGODB_BASE_PATH}/doc.
KONGODB_DOCS_ENABLED=true

# ============================================================
# Storage
# ============================================================
# DATA_DIR is the persistent volume mount point inside the container. It must be writable by the container.
KONGODB_DATA_DIR=./data

# STORAGE_MODE:
# local: durable local DB files;
# s3: local working files plus S3 WAL/snapshots.
KONGODB_STORAGE_MODE=local

# Required when KONGODB_STORAGE_MODE=s3.
KONGODB_S3_BUCKET=
KONGODB_S3_PREFIX=data/kongo/data
KONGODB_S3_REGION=us-east-1
KONGODB_S3_ENDPOINT=
KONGODB_S3_ACCESS_KEY=
KONGODB_S3_SECRET_KEY=
KONGODB_S3_SESSION_TOKEN=

# ============================================================
# Runtime profile and bounded concurrency
# ============================================================
# balanced: standard defaults; memory: smaller caches/queues; throughput: larger batches/concurrency.
KONGODB_RUNTIME_PROFILE=balanced
# Optional profile override for the active/open DB LRU cap.
KONGODB_MAX_ACTIVE_DBS=100
# Shared concurrency budget for reaper, backup, job, and remote-sync DB work.
KONGODB_WORKER_CONCURRENCY=4

# ============================================================
# S3 replication and snapshots
# ============================================================
# sync waits for remote replication; async flushes in the background.
KONGODB_REPLICATION_MODE=async
# Comma-separated DB paths to load at startup in s3 mode.
KONGODB_PRELOAD_DBS=
# Create a portable snapshot after this many writes.
KONGODB_SNAPSHOT_EVERY_WRITES=100
KONGODB_SNAPSHOT_RETENTION_DAYS=14
# Remote snapshot polling interval. 0 disables cross-instance polling.
KONGODB_REMOTE_SYNC_INTERVAL_SECS=3

# ============================================================
# Read, write, query, and response behavior
# ============================================================
# Read cache TTL. 0 disables the read cache.
KONGODB_CACHE_TTL_SECS=15
# direct bypasses the coordinator; committed waits; accepted queues and acknowledges.
KONGODB_WRITE_MODE=committed
KONGODB_QUERY_DEFAULT_LIMIT=50
KONGODB_QUERY_LOOKUP_MAX_DEPTH=3
KONGODB_QUERY_LOOKUP_UNCAPPED_OVERRIDE_ENABLED=false
KONGODB_RESPONSE_INCLUDE_SYSTEM_TIMESTAMPS=true
KONGODB_RESPONSE_INCLUDE_NAMESPACE=false
KONGODB_STRICT_MUTATIONS_OPERATORS=false

# ============================================================
# Data lifecycle
# ============================================================
# Empty means no automatic archive purge/default delete TTL.
KONGODB_ARCHIVE_TTL_SECS=
KONGODB_DELETE_DEFAULT_TTL_SECS=
# Internal system catalog history retention.
KONGODB_SYSTEM_RETENTION_DAYS=14

# ============================================================
# Metric events
# ============================================================
# Metrics are always available. Cache TTL 0 disables only metrics-query caching.
KONGODB_METRIC_EVENTS_CACHE_TTL_SECS=30
# Empty keeps raw metric events indefinitely.
KONGODB_METRIC_EVENTS_RETENTION_DAYS=

# ============================================================
# Backup, export, and background jobs
# ============================================================
# Local path or full s3://bucket/prefix. Used by manual and automatic backups.
KONGODB_BACKUP_PATH=./backups
# 0 disables automatic backup. Positive values provide change-aware max staleness.
KONGODB_BACKUP_EVERY_SECS=0
KONGODB_BACKUP_RETENTION_DAYS=30
# Local path or full s3://bucket/prefix for generated JSONL exports.
KONGODB_EXPORT_PATH=./exports
# Shared retention for terminal import/export job history.
KONGODB_JOB_RETENTION_DAYS=30

# ============================================================
# Legacy field aliases
# ============================================================
KONGODB_ENABLE_LEGACY_ALIASES=false
KONGODB_LEGACY_ALIASES_IMPORT_PK=_key:_id
KONGODB_LEGACY_ALIASES_RESPONSE=_key:_id

# SQL execution, FTS capability, metric events, auto-indexing, JSONB, system
# catalog, safe hydration, temp cleanup, and job workers are core features and
# are always enabled. Their safety thresholds use internal defaults.
